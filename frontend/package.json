{
  "name": "bilibili-danmaku-player",
  "version": "1.0.0",
  "description": "B站风格桌面弹幕播放器",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --enable-logging",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "keywords": [
    "electron",
    "bilibili",
    "danmaku",
    "player"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {},
  "build": {
    "appId": "com.bilibili.danmaku-player",
    "productName": "B站弹幕播放器",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "renderer.js",
      "icon/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "icon/theme.jpg"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "icon/theme.jpg"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "icon/theme.jpg"
    }
  }
}
